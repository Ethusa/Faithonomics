# Public browser configuration
VITE_WIX_SITE_ID=
VITE_WIX_CLIENT_ID=
VITE_WIX_SITE_BASE_URL=https://www.mycollege.co.za
VITE_STUDENT_PORTAL_URL=https://www.mycollege.co.za/student-portal
VITE_CLASSROOM_API_BASE=/api
VITE_APP_NAMESPACE=<app-namespace>
VITE_ENABLE_DEMO_DATA=true

# GitHub Pages + Supabase external data basis
# Leave as mock until Supabase is created and seeded.
VITE_BACKEND_PROVIDER=mock
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_SUPABASE_TABLE=classroom_records

# Backend-only configuration. Store production values in Wix Secrets Manager.
WIX_APP_ID=
WIX_APP_NAMESPACE=<app-namespace>
WIX_SITE_ID=
OPENAI_SECRET_NAME=OPENAI_API_KEY
OPENAI_MODEL=gpt-4.1-mini
AI_DAILY_LIMIT_PER_LEARNER=8
